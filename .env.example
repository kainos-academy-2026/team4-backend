# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="******localhost:5432/job_roles_db?schema=public"

# JWT  - replace with 64-byte secrets encoded as hex (128 chars)
JWT_ACCESS_SECRET="replace_with_128_hex_chars"

# Token TTLs - 15m = 15 minutes, 7d = 7 days
ACCESS_TOKEN_TTL="15m"

# Optional local development credentials used by prisma seed
ENABLE_DEV_TEST_USER="false"
TEST_USER_EMAIL="test@example.com"
TEST_USER_PASSWORD="Password123!"
TEST_ADMIN_EMAIL="admin@example.com"
TEST_ADMIN_PASSWORD="AdminPassword123!"

# AWS S3
AWS_REGION=eu-west-1
S3_BUCKET_NAME=your-bucket-name
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# Frontend origin for S3 CORS policy (used by npm run s3:set-cors)
FRONTEND_ORIGIN=http://localhost:3000
