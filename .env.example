# Server
PORT=3000
NODE_ENV=development

# Database - replace with PostgreSQL database URL
DATABASE_URL="postgresql://user:password@localhost:5432/team4_backend"

# JWT  - replace with 64-byte secrets encoded as hex (128 chars)
JWT_ACCESS_SECRET="replace_with_128_hex_chars"
JWT_REFRESH_SECRET="replace_with_128_hex_chars"

# Token TTLs - 7d = 7 days, 15m = 15 minutes
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL="7d"

# Optional local development credentials used by prisma seed
ENABLE_DEV_TEST_USER="true"
TEST_USER_EMAIL="test@example.com"
TEST_USER_PASSWORD="Password123!"
TEST_ADMIN_EMAIL="admin@example.com"
TEST_ADMIN_PASSWORD="AdminPassword123!"
