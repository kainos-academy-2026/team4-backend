{
	"name": "team4-backend",
	"version": "1.0.0",
	"private": true,
	"description": "Basic Express API backend",
	"main": "dist/index.js",
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"dev": "tsx watch src/index.ts",
		"start": "node dist/index.js",
		"format": "biome format --write .",
		"lint": "biome lint --write .",
		"check": "biome check --write .",
		"ci:check": "biome ci"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"express": "^5.1.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.2",
		"@types/express": "^5.0.3",
		"@types/node": "^24.0.13",
		"tsx": "^4.20.3",
		"typescript": "^5.8.3"
	}
}
