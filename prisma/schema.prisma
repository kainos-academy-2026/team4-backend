generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid()) // Identify user row
  email        String   @unique
  role         String   @default("user") // user = applicant, admin = recruiter
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Capability {
  id             Int       @id @default(autoincrement())
  capabilityName String
  jobRoles       JobRole[]
}

model Band {
  id       Int       @id @default(autoincrement())
  bandName String
  jobRoles JobRole[]
}

model JobRole {
  id           Int      @id @default(autoincrement())
  roleName     String
  location     String
  capabilityId Int
  bandId       Int
  closingDate  DateTime
  status       String
  description  String
  responsibilities String
  sharepointUrl String?
  numberOfOpenPositions Int?

  capability Capability @relation(fields: [capabilityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  band       Band       @relation(fields: [bandId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([capabilityId])
  @@index([bandId])
}
